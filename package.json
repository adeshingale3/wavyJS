{
  "name": "wavyjs",
  "description": "A npm package for React hooks and UI Components.",
  "private": false,
  "version": "1.0.2",
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "dist/style.css",
    "dist/index.css",
    "components/cursor/FollowCursor/FollowCursor.css"
  ],
  "style": "dist/style.css",
  "sass": "dist/style.css",
  "repository": {
    "type": "git",
    "url": "https://github.com/adeshingale3/wavyJS.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && npm run build:styles",
    "build:styles": "postcss ./src/index.css -o ./dist/style.css",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "author": "Adesh Ingale",
  "license":"MIT",
  "keywords": ["hooks", "ui components", "wavyjs"],
  "peerDependencies": {
    "autoprefixer": "^10.0.0",
    "postcss": "^8.0.0",
    "react": "^18.3.1 || ^19.0.0",
    "react-dom": "^18.3.1 || ^19.0.0",
    "tailwindcss": "^3.0.0 || ^4.0.0"
  },
  "dependencies": {
    
    "class-variance-authority": "^0.6.0",
    "clsx": "^1.2.1",
    "lucide-react": "^0.518.0",
    
    "tailwind-merge": "^1.12.0",
    "tailwindcss-animate": "^1.0.5"
  },
  "devDependencies": {
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@typescript-eslint/eslint-plugin": "^5.57.1",
    "@typescript-eslint/parser": "^5.57.1",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.38.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.3.4",
    "postcss": "^8.5.6",
    "postcss-cli": "^10.1.0",
    "postcss-prefix-selector": "^2.1.1",
    "prop-types": "^15.8.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.0.2",
    "vite": "^4.3.2",
    "vite-plugin-dts": "^2.3.0"
  }
}
